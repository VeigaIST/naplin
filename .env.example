# Copy to .env — generate AUTH_SECRET: openssl rand -base64 32
# Postgres (local Docker, Neon, etc. — Vercel uses Neon via integration)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/naplin"
AUTH_SECRET="replace-with-at-least-32-character-secret-string"

# Optional: public base URL for magic links (on Vercel, VERCEL_URL is used if unset)
NEXT_PUBLIC_APP_URL="http://localhost:3030"

# Seed script (optional; defaults below if unset)
# ADMIN_SEED_EMAIL="admin@naplin.local"
# ADMIN_SEED_PASSWORD="changeme-naplin"
# PARTICIPANT_SEED_CODE_NO_PIN="DEMO00"
# PARTICIPANT_SEED_CODE="DEMO01"
# PARTICIPANT_SEED_PIN="1234"
# PARTICIPANT_SEED_MAGIC_TOKEN_NO_PIN="local-dev-magic-demo00"
# PARTICIPANT_SEED_MAGIC_TOKEN="local-dev-magic-demo01"
#
# After `npx prisma db seed`: admin + DEMO00 (no PIN) + DEMO01 (PIN 1234).
